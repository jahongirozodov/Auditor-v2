<UserControl x:Class="Auditor.Agent.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel MaxWidth="560">
        <TextBlock Text="Sozlamalar" Style="{StaticResource H1}" Margin="0,0,0,16" />

        <TextBlock Text="SERVER MANZILI" Style="{StaticResource FieldLabel}" />
        <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" FontFamily="{StaticResource FontMono}" Margin="0,0,0,12" />

        <TextBlock Text="SINXRONLASH DAVRI (DAQIQA)" Style="{StaticResource FieldLabel}" />
        <TextBox Text="{Binding SyncInterval, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Lokal shifrlash" Foreground="{StaticResource TextSecondary}" FontSize="13" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Success}" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Encryption}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Success}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Agent versiyasi" Foreground="{StaticResource TextSecondary}" FontSize="13" />
                <TextBlock HorizontalAlignment="Right" Text="{Binding VersionLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
            </DockPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
            <Button Content="Yangilanishni tekshirish" Style="{StaticResource BtnGhost}" Command="{Binding CheckUpdateCommand}" />
            <TextBlock Text="{Binding UpdateLabel}" Style="{StaticResource Meta}" VerticalAlignment="Center" Margin="10,0,0,0" />
        </StackPanel>

        <Button Content="Saqlash" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Left" Margin="0,16,0,0" Command="{Binding SaveCommand}" />

        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,16,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="Logout &amp; token bekor qilish" Style="{StaticResource BtnDanger}" Command="{Binding LogoutCommand}" />
                <TextBlock HorizontalAlignment="Right" Text="© 2026 Audit boshqaruvi" Style="{StaticResource Meta}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </StackPanel>
</UserControl>
