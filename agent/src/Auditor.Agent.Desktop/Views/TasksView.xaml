<UserControl x:Class="Auditor.Agent.Desktop.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Mening vazifalarim" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding Summary}" Style="{StaticResource Meta}" Margin="0,4,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Sync"
                    Style="{StaticResource BtnSoft}" Command="{Binding SyncNowCommand}" />
        </DockPanel>

        <ItemsControl ItemsSource="{Binding Tasks}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource LRow}" Margin="0,0,0,8">
                        <DockPanel>
                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding Done}" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource Tag}" Background="{Binding StatusKind, Converter={StaticResource KindToBrush}}">
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="{StaticResource TextPrimary}" />
                                </Border>
                                <TextBlock Text="{Binding Findings}" Style="{StaticResource Meta}" Margin="10,0,0,0"
                                           Visibility="{Binding Findings, Converter={StaticResource CountToVis}}" />
                                <Button Margin="8,0,0,0" Style="{StaticResource BtnGhost}" Content="+ Finding"
                                        Command="{Binding DataContext.NewFindingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding Id}" Style="{StaticResource MetaLabel}" FontFamily="{StaticResource FontMono}" />
                                    <TextBlock Text="{Binding Type}" Style="{StaticResource MetaLabel}" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding Priority}" Style="{StaticResource MetaLabel}" Margin="8,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
