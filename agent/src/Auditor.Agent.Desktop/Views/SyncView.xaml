<UserControl x:Class="Auditor.Agent.Desktop.Views.SyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Sinxronlash" Style="{StaticResource H1}" />
                <TextBlock Text="Server bilan maʼlumotlarni almashtirish navbati" Style="{StaticResource Meta}" Margin="0,4,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Content="Hozir sinxronla"
                    Style="{StaticResource BtnPrimary}" Command="{Binding SyncNowCommand}"
                    IsEnabled="{Binding Busy, Converter={StaticResource NotBool}}" />
        </DockPanel>

        <!-- Status banner -->
        <Border Background="{StaticResource SuccessBg}" BorderBrush="{StaticResource Success}" BorderThickness="1"
                CornerRadius="8" Padding="14" Margin="0,0,0,14">
            <DockPanel>
                <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="14" Background="{StaticResource Success}" Margin="0,0,12,0">
                    <TextBlock Text="&#xE701;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Onlayn · server bilan aloqada" FontWeight="SemiBold" Foreground="{StaticResource Success}" FontSize="13" />
                    <TextBlock Text="{Binding BannerSub}" Style="{StaticResource Meta}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Queue -->
        <Border Style="{StaticResource Panel}" Padding="0" Margin="0,0,0,14">
            <StackPanel>
                <DockPanel Margin="14,12,14,8">
                    <TextBlock Text="Yuborish navbati" FontWeight="SemiBold" />
                </DockPanel>
                <ItemsControl ItemsSource="{Binding Queue}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" Style="{StaticResource Tag}">
                                            <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{StaticResource TextMuted}" />
                                        </Border>
                                        <TextBlock Text="{Binding Item}" FontSize="13" Foreground="{StaticResource TextPrimary}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,6,0,0">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Size}" Style="{StaticResource Meta}" />
                                        <ProgressBar Height="6" Value="{Binding Percent}" Maximum="100" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <TextBlock Text="Oxirgi sinxronlash loglari" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6" />
        <TextBox Style="{StaticResource CodeBlock}" Text="{Binding Logs, Mode=OneWay}" Height="160" />
    </StackPanel>
</UserControl>
