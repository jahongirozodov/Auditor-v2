<UserControl x:Class="Auditor.Agent.Desktop.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Lokal log" Style="{StaticResource H1}" Margin="0,0,0,14" />
        <TextBox Style="{StaticResource CodeBlock}" Text="{Binding Logs, Mode=OneWay}" Height="420" />
    </StackPanel>
</UserControl>
