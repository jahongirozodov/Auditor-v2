<UserControl x:Class="Auditor.Agent.Desktop.Views.TokenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Width="440" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="{StaticResource BgSurface2Brush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="16" Padding="40,36">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.45" Color="#000000" />
            </Border.Effect>
            <StackPanel>
                <Border Width="60" Height="60" CornerRadius="16" Background="{StaticResource BgSurface3Brush}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#xE192;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                               Foreground="{StaticResource PrimaryHover}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Audit tokenni kiriting" FontFamily="{StaticResource FontDisplay}" FontSize="20"
                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center" Margin="0,16,0,6" />
                <TextBlock TextAlignment="Center" Style="{StaticResource Meta}" Margin="0,0,0,22"
                           Text="Token web tizimda audit kartasidan olinadi. Token faqat shu audit doirasidagi vazifalarni ochadi." />

                <TextBox Text="{Binding TokenText, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource FontMono}" TextAlignment="Center" FontSize="14" Margin="0,0,0,14" />

                <TextBlock Text="{Binding Error}" Foreground="{StaticResource Danger}" FontSize="12.5"
                           TextWrapping="Wrap" Visibility="{Binding Error, Converter={StaticResource StringToVis}}"
                           Margin="0,0,0,12" />

                <Button Content="Tasdiqlash va vazifalarni yuklash" Style="{StaticResource BtnPrimary}"
                        FontSize="14" Padding="14,11"
                        Command="{Binding ConfirmCommand}" IsEnabled="{Binding Busy, Converter={StaticResource NotBool}}" />
                <Button Content="Orqaga" Style="{StaticResource BtnGhost}" Margin="0,10,0,0"
                        Command="{Binding BackCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
