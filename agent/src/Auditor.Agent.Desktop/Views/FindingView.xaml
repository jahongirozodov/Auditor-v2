<UserControl x:Class="Auditor.Agent.Desktop.Views.FindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" DragOver="Root_DragOver" Drop="Root_Drop">
    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
        <!-- Header -->
        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Yangi finding" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Meta}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis">
                    <Run Text="{Binding TaskId, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding TaskTitle, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
            <Border Grid.Column="1" VerticalAlignment="Top" Style="{StaticResource Tag}"
                    Background="{StaticResource WarningBg}" Margin="12,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                               Foreground="{StaticResource Warning}" VerticalAlignment="Center" />
                    <TextBlock Text="Lokal qoralama" FontSize="11" Foreground="{StaticResource Warning}"
                               Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Text="Sarlavha *" Style="{StaticResource FieldLabel}" />
        <Grid Margin="0,0,0,14">
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Topilma nomini yozing" Foreground="{StaticResource TextMuted}" FontSize="13"
                       Margin="13,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                       Visibility="{Binding Title, Converter={StaticResource EmptyToVis}}" />
        </Grid>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="150" /><ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" MinWidth="90" /><ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" MinWidth="110" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Xavf darajasi" Style="{StaticResource FieldLabel}" />
                <ComboBox ItemsSource="{Binding Severities}" SelectedItem="{Binding Severity}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                         Fill="{Binding Converter={StaticResource SeverityToBrush}}" />
                                <TextBlock Text="{Binding Converter={StaticResource SeverityToLabel}}" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="CVSS 3.1" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Cvss, UpdateSourceTrigger=PropertyChanged}" FontFamily="{StaticResource FontMono}" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="CWE" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Cwe, UpdateSourceTrigger=PropertyChanged}" FontFamily="{StaticResource FontMono}" />
            </StackPanel>
        </Grid>

        <TextBlock Text="Asset" Style="{StaticResource FieldLabel}" />
        <Grid Margin="0,0,0,14">
            <TextBox Text="{Binding Asset, UpdateSourceTrigger=PropertyChanged}" FontFamily="{StaticResource FontMono}" />
            <TextBlock Text="masalan: FW-CORE-01" Foreground="{StaticResource TextMuted}" FontSize="13" FontFamily="{StaticResource FontMono}"
                       Margin="13,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                       Visibility="{Binding Asset, Converter={StaticResource EmptyToVis}}" />
        </Grid>

        <TextBlock Text="Tavsif" Style="{StaticResource FieldLabel}" />
        <Grid Margin="0,0,0,14">
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                     TextWrapping="Wrap" MinHeight="96" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" />
            <TextBlock Text="Topilma tavsifi, taʼsiri va tekshirish qadamlari" Foreground="{StaticResource TextMuted}" FontSize="13"
                       Margin="13,11,0,0" VerticalAlignment="Top" IsHitTestVisible="False"
                       Visibility="{Binding Description, Converter={StaticResource EmptyToVis}}" />
        </Grid>

        <!-- Evidence -->
        <TextBlock Style="{StaticResource FieldLabel}">
            <Run Text="Dalillar (" /><Run Text="{Binding EvidenceCount, Mode=OneWay}" /><Run Text=")" />
        </TextBlock>

        <ItemsControl ItemsSource="{Binding Evidence}" Margin="0,0,0,8"
                      Visibility="{Binding EvidenceCount, Converter={StaticResource CountToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource BgSurface3Brush}" CornerRadius="8" Padding="6,5" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="6"
                                    Background="{StaticResource BgSurfaceBrush}" ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="{Binding Glyph}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="{StaticResource TextMuted}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                </Grid>
                            </Border>
                            <StackPanel Margin="8,0,6,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="12" FontFamily="{StaticResource FontMono}"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="180" />
                                <TextBlock Text="{Binding SizeLabel}" FontSize="10.5" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0" />
                            </StackPanel>
                            <Button Style="{StaticResource ChipClose}" Content="&#xE711;"
                                    Command="{Binding RemoveCommand}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Drop zone -->
        <Grid Margin="0,0,0,14" Height="118">
            <Rectangle RadiusX="10" RadiusY="10" Stroke="{StaticResource BorderStrongBrush}"
                       StrokeThickness="1.4" StrokeDashArray="4 3" Fill="{StaticResource BgSurfaceBrush}" />
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" />
                <TextBlock Text="Fayllarni bu yerga tashlang yoki tugmani bosing" Foreground="{StaticResource TextMuted}"
                           FontSize="12.5" HorizontalAlignment="Center" Margin="0,6,0,0" />
                <Button Content="Biriktirish" Style="{StaticResource BtnSoft}" Command="{Binding AttachCommand}"
                        HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <TextBlock Text="{Binding Error}" Foreground="{StaticResource Danger}"
                   Visibility="{Binding Error, Converter={StaticResource StringToVis}}" Margin="0,0,0,8" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Bekor" Style="{StaticResource BtnGhost}" Command="{Binding CancelCommand}" />
            <Button Content="Lokal saqlash" Style="{StaticResource BtnSoft}" Margin="8,0,0,0" Command="{Binding SaveLocalCommand}" />
            <Button Content="Yuborish" Style="{StaticResource BtnPrimary}" Margin="8,0,0,0" Command="{Binding SendCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
