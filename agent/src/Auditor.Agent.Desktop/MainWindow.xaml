<Window x:Class="Auditor.Agent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auditor Agent" Height="640" Width="940"
        MinHeight="560" MinWidth="820"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BgPageBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="Glyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Title bar ===== -->
        <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Height="34">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Style="{StaticResource Glyph}" Text="&#xE83D;" FontSize="13"
                               Foreground="{StaticResource PrimaryHover}" />
                    <TextBlock Text="{Binding TitleText}" Margin="8,0,0,0" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource WinBtn}" Click="Minimize_Click">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE921;" FontSize="10" />
                    </Button>
                    <Button Style="{StaticResource WinBtn}" Click="Maximize_Click">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE922;" FontSize="10" />
                    </Button>
                    <Button Style="{StaticResource WinBtnClose}" Click="Close_Click">
                        <TextBlock Style="{StaticResource Glyph}" Text="&#xE8BB;" FontSize="10" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Body ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Width="214" Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                    Padding="10" Visibility="{Binding SidebarVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <!-- Token card -->
                    <Border Background="{StaticResource BgSurface2Brush}" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="AUDIT TOKEN" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" />
                            <TextBlock Text="{Binding TokenMasked}" FontFamily="{StaticResource FontMono}"
                                       FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding TokenAudit}" FontSize="10"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Nav -->
                    <RadioButton GroupName="nav" Style="{StaticResource NavItem}" Command="{Binding NavTasksCommand}"
                                 IsChecked="{Binding ActiveNav, Converter={StaticResource StrEq}, ConverterParameter=tasks, Mode=OneWay}">
                        <DockPanel>
                            <TextBlock Style="{StaticResource Glyph}" Text="&#xE73A;" FontSize="14" />
                            <Border DockPanel.Dock="Right" Style="{StaticResource Badge}"
                                    Visibility="{Binding DataContext.TasksCount, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource CountToVis}}">
                                <TextBlock Text="{Binding DataContext.TasksCount, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                            </Border>
                            <TextBlock Text="Mening vazifalarim" Margin="10,0,0,0" />
                        </DockPanel>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavItem}" Command="{Binding NavFindingsCommand}"
                                 IsChecked="{Binding ActiveNav, Converter={StaticResource StrEq}, ConverterParameter=findings, Mode=OneWay}">
                        <DockPanel>
                            <TextBlock Style="{StaticResource Glyph}" Text="&#xE7BA;" FontSize="14" />
                            <Border DockPanel.Dock="Right" Style="{StaticResource Badge}"
                                    Visibility="{Binding DataContext.FindingsCount, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource CountToVis}}">
                                <TextBlock Text="{Binding DataContext.FindingsCount, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                            </Border>
                            <TextBlock Text="Findinglar (lokal)" Margin="10,0,0,0" />
                        </DockPanel>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavItem}" Command="{Binding NavFilesCommand}"
                                 IsChecked="{Binding ActiveNav, Converter={StaticResource StrEq}, ConverterParameter=files, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Glyph}" Text="&#xE8B7;" FontSize="14" />
                            <TextBlock Text="Fayllar" Margin="10,0,0,0" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavItem}" Command="{Binding NavSyncCommand}"
                                 IsChecked="{Binding ActiveNav, Converter={StaticResource StrEq}, ConverterParameter=sync, Mode=OneWay}">
                        <DockPanel>
                            <TextBlock Style="{StaticResource Glyph}" Text="&#xE72C;" FontSize="14" />
                            <Border DockPanel.Dock="Right" Style="{StaticResource Badge}"
                                    Visibility="{Binding DataContext.SyncCount, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource CountToVis}}">
                                <TextBlock Text="{Binding DataContext.SyncCount, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="11" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                            </Border>
                            <TextBlock Text="Sinxronlash" Margin="10,0,0,0" />
                        </DockPanel>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavItem}" Command="{Binding NavLogCommand}"
                                 IsChecked="{Binding ActiveNav, Converter={StaticResource StrEq}, ConverterParameter=log, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Glyph}" Text="&#xE81C;" FontSize="14" />
                            <TextBlock Text="Lokal log" Margin="10,0,0,0" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="nav" Style="{StaticResource NavItem}" Command="{Binding NavSettingsCommand}"
                                 IsChecked="{Binding ActiveNav, Converter={StaticResource StrEq}, ConverterParameter=settings, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Glyph}" Text="&#xE713;" FontSize="14" />
                            <TextBlock Text="Sozlamalar" Margin="10,0,0,0" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Content + toast overlay -->
            <Grid Grid.Column="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18">
                    <ContentControl Content="{Binding CurrentView}" HorizontalAlignment="Stretch" />
                </ScrollViewer>
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,16"
                        Background="{StaticResource BgSurface3Brush}" BorderBrush="{StaticResource BorderStrongBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,9"
                        Visibility="{Binding Toast, Converter={StaticResource StringToVis}}">
                    <TextBlock Text="{Binding Toast}" Foreground="{StaticResource TextPrimary}" FontSize="12.5" />
                </Border>
            </Grid>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel LastChildFill="False">
                <Ellipse DockPanel.Dock="Left" Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{Binding Online, Converter={StaticResource OnlineToBrush}}" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Margin="7,0,0,0" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding LastSyncText}" Margin="16,0,0,0" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding Drafts, StringFormat=Qoralama: {0}}" Margin="16,0,0,0" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding Pending, StringFormat=Yuborilmagan: {0}}" Margin="16,0,0,0" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding Version}" Margin="16,0,0,0" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding UserIp}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
