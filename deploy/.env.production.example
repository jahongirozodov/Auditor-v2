# =============================================================================
# Auditor — production environment variables
# Copy to /opt/auditor/web/.env.production and fill in all values.
# NEVER commit this file with real credentials.
# =============================================================================

# ---- Database ---------------------------------------------------------------
# Replace <PG_PASS> with the password from /root/pg_auditor_password.txt
DATABASE_URL=postgresql://auditor:<PG_PASS>@localhost:5432/auditor
DIRECT_URL=postgresql://auditor:<PG_PASS>@localhost:5432/auditor

# ---- Auth.js ----------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_BASE64

# ---- AI / Ollama (optional — leave as-is if Ollama runs on same host) ------
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen/qwen3-coder-30b

# ---- Next.js ----------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
