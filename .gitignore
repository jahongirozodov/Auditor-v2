# Repo-root ignores. The Next.js app (web/) has its own .gitignore too.

# Dependencies
**/node_modules/

# Build output
**/.next/
**/out/
**/build/
**/dist/

# Environment / secrets — never commit
**/.env
**/.env.local
**/.env.*.local

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Test / coverage
**/coverage/

# .NET agent — build output (never commit binaries or obj cache)
agent/publish/
agent/publish_tmp/
agent/src/**/bin/
agent/src/**/obj/
agent/Screenshot*.png

# Root-level publish dir (CI artifact, not source)
publish/
panel.png

# Claude worktrees — ephemeral, not part of the project
.claire/
