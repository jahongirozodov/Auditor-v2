# Repo-root ignores. The Next.js app (web/) has its own .gitignore too.

# Dependencies
**/node_modules/

# Build output
**/.next/
**/out/
**/build/
**/dist/

# Environment / secrets — never commit
**/.env
**/.env.local
**/.env.*.local

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Test / coverage
**/coverage/
