{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/badges/**",
              "components/buttons/**",
              "components/charts/**",
              "components/data-display/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/auditor/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Manrope|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Manrope, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarUser'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|avatar|name|key|ref|className|style|children)$/]",
        "message": "<AvatarUser> doesn't accept that prop. Declared props: initials, avatar, name."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|iconOnly|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, iconOnly, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DonutItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|color|label|key|ref|className|style|children)$/]",
        "message": "<DonutItem> doesn't accept that prop. Declared props: value, color, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:iconLeft|as|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: iconLeft, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|select|textarea)$/]",
        "message": "<Input> as must be one of 'input' | 'select' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sev'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|className|key|ref|className|style|children)$/]",
        "message": "<Sev> doesn't accept that prop. Declared props: level, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|w|h|color|fill|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, w, h, color, fill."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|delta|deltaNeg|meta|bar|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: icon, label, value, delta, deltaNeg, meta, bar."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, icon, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, icon, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
