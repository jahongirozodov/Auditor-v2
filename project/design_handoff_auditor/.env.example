# =========================================================================
# Auditor — environment variables (namuna). `.env.local` ga ko'chirib to'ldiring.
# HECH QACHON haqiqiy qiymatlarni commit qilmang.
# =========================================================================

# --- Database (PostgreSQL, RLS bilan) ---
DATABASE_URL="postgresql://user:password@localhost:5432/auditor?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/auditor?schema=public"

# --- Auth.js (NextAuth) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# --- Active Directory / LDAP (domen hisobi) ---
LDAP_URL="ldaps://dc-01.gov.uz:636"
LDAP_BIND_DN="CN=svc-auditor,OU=Service,DC=gov,DC=uz"
LDAP_BIND_PASSWORD=""
LDAP_SEARCH_BASE="OU=Users,DC=gov,DC=uz"

# --- Lokal Ollama (yopiq kontur AI) ---
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:14b-instruct"
OLLAMA_MAX_TOKENS="8192"
OLLAMA_TEMPERATURE="0.2"

# --- SMTP (bildirishnomalar) ---
SMTP_HOST="smtp.gov.uz"
SMTP_PORT="587"
SMTP_USER="auditor@gov.uz"
SMTP_PASSWORD=""
SMTP_FROM="Auditor <auditor@gov.uz>"

# --- Xavfsizlik ---
ARGON2_MEMORY_COST="65536"
ARGON2_TIME_COST="3"
ARGON2_PARALLELISM="4"
SESSION_MAX_AGE_HOURS="8"          # "Bu qurilmani 8 soatga eslab qol"
LOGIN_LOCKOUT_ATTEMPTS="5"
LOGIN_LOCKOUT_MINUTES="15"
AUDIT_LOG_RETENTION_YEARS="7"

# --- Muhit ---
NODE_ENV="development"
CLOSED_NETWORK="true"              # tashqi tarmoq chaqiruvlarini bloklash
